{
    "name": "aybarsm/chief",
    "description": "An opinionated PHP command-line toolkit",
    "keywords": ["framework", "laravel", "laravel zero", "console", "cli"],
    "homepage": "https://github.com/aybarsm/chief",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/aybarsm/chief/issues",
        "source": "https://github.com/aybarsm/chief"
    },
    "authors": [
        {
            "name": "Murat Aybars",
            "email": "murat.aybars@blrm.co"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/http": "^12.17",
        "illuminate/log": "^12.17",
        "illuminate/view": "^12.17",
        "laravel-zero/framework": "^12.0.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["chief"]
}
